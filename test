local function runLoader()
    task.wait(0.5)
    statusLbl.Text="Stripping & patching modules..."
    TweenService:Create(progBar,TweenInfo.new(0.8,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(0.4,0,1,0)}):Play()
    task.wait(0.9)
    statusLbl.Text="Verifying client rank..."
    TweenService:Create(progBar,TweenInfo.new(0.6,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(0.7,0,1,0)}):Play()
    task.wait(0.7)
    statusLbl.Text=isPremium and "Welcome, Premium User!" or "Welcome, Free User!"
    if isPremium then statusLbl.TextColor3=Color3.fromRGB(100,220,130) end
    TweenService:Create(progBar,TweenInfo.new(0.5,Enum.EasingStyle.Linear),{Size=UDim2.new(1,0,1,0)}):Play()
    task.wait(0.6)
    for _,o in pairs({loaderMain,barBg,progBar}) do TweenService:Create(o,TweenInfo.new(0.3),{BackgroundTransparency=1}):Play() end
    TweenService:Create(titleLbl,TweenInfo.new(0.3),{TextTransparency=1}):Play()
    TweenService:Create(statusLbl,TweenInfo.new(0.3),{TextTransparency=1}):Play()
    loaderStroke:Destroy(); task.wait(0.35); loaderGui:Destroy()
    playLoadSound(); initializeHub()
end

