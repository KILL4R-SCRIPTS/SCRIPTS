    local function fireBuy(sellerObj,uuid,price,displayName)
        if inFlight[uuid] or ownedListings[uuid] then return end
        inFlight[uuid]=true
        task.spawn(function()
            local ok,res=pcall(function() return PurchaseSaleListing:InvokeServer(sellerObj,"Sign",tostring(uuid)) end)
            if ok and res then
