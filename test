            else task.wait(0.5) end
            inFlight[uuid]=nil
        end)
    end

    -- Load a player's inventory via Replion and attempt to buy their sign listings
    local function scanPlayerSign(player)
        if not PurchaseSaleListing then return 0 end
        local ok2, ReplionClient = pcall(require, RS.Modules.Replion.Client)
        if not ok2 then return 0 end

        local LoadPlayerInventory = Net:FindFirstChild("RF/Trading/LoadPlayerInventory", true)
        if not LoadPlayerInventory then return 0 end

        -- Load their inventory into Replion
        local loadOk, tag = pcall(function() return LoadPlayerInventory:InvokeServer(player) end)
        if not loadOk or not tag then return 0 end

        task.wait(0.3)

        -- Get their replion
        local repOk, rep = pcall(function() return ReplionClient:GetReplion(tag) end)
        if not repOk or not rep then return 0 end

        -- Get Sign data
        local signOk, signData = pcall(function() return rep:Get("Sign") end)
        if not signOk or type(signData) ~= "table" then return 0 end

        local count = 0
        for uuid, data in pairs(signData) do
            if ownedListings[uuid] or inFlight[uuid] then continue end
            local itemName = ""
            if type(data) == "table" then
                if data.Item then pcall(function() itemName = tostring(data.Item.Name) end) end
                if itemName == "" then itemName = tostring(data.ItemName or "") end
            end
            local price = type(data) == "table" and tonumber(data.Price or 0) or 0
            local maxAllowed = ITEM_PRICES[itemName]
            if maxAllowed and price <= maxAllowed then
                fireBuy(player, uuid, price, itemName)
                count = count + 1
            end
        end
        return count
    end

    local function scanAndBuy()
        local pb = PurchaseSaleListing or Net:FindFirstChild("RF/Trading/PurchaseSaleListing",true)
        if pb then PurchaseSaleListing=pb end
        if not PurchaseSaleListing then return 0 end

        local count = 0

        -- Method 1: FindSellers (works in Trading Plaza)
        local pl = FindSellers or Net:FindFirstChild("RF/Trading/FindSellers",true)
        if pl then FindSellers=pl end
        if FindSellers then
            local ok,result=pcall(function() return FindSellers:InvokeServer() end)
            if ok and type(result)=="table" then
                for uuid,data in pairs(result) do
                    if not ownedListings[uuid] and not inFlight[uuid] then
                        local itemName=getItemName(data); local price=tonumber(data.Price or 0)
                        local maxAllowed=ITEM_PRICES[itemName]
                        if maxAllowed and price<=maxAllowed then
                            local sellerObj=Players:GetPlayerByUserId(tonumber(data.SellerUserId or data.UserId or 0))
                            if sellerObj and sellerObj~=LocalPlayer then
                                fireBuy(sellerObj,uuid,price,itemName); count=count+1
                            end
                        end
                    end
                end
                return count -- Trading Plaza done
            end
        end

        -- Method 2 (Baddies): load each player's inventory via Replion and check their Sign
        for _,player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                count = count + (scanPlayerSign(player) or 0)
                task.wait(0.1)
            end
        end

        return count
    end

