    local function _abGetName(d)
        local n=""
        if type(d)=="table" and d.Item then pcall(function() n=tostring(d.Item.Name) end) end
        return n
    end

    local function _abTryBuy(owner,uuid,listing)
        if inFlight[uuid] then return end
        inFlight[uuid]=true
        task.spawn(function()
            local ok,res=pcall(function() return _abPurchase:InvokeServer(owner,"Sign",uuid) end)
            if ok and res~=false then
                autoBoughtCount=autoBoughtCount+1
                autoBoughtSpent=autoBoughtSpent+(tonumber(listing.Price or 0) or 0)
            end
            inFlight[uuid]=nil
        end)
    end

    local function _abScanAll()
        if not _abPurchase or not _abSaleListings then return end
        local all=_abSaleListings:Get({"Players"})
        if type(all)~="table" then return end
        for uid,pd in pairs(all) do
            if not autoBuyActive then break end
            local sign=pd and pd.Sign
            if type(sign)~="table" then continue end
            local userId=tonumber(uid)
            local owner=userId and Players:GetPlayerByUserId(userId)
            if not owner or owner==LocalPlayer then continue end
            for uuid,listing in pairs(sign) do
                if type(listing)~="table" or inFlight[uuid] then continue end
                local name=_abGetName(listing)
                local price=tonumber(listing.Price or 0) or 0
                local maxVal=ITEM_PRICES[name]
                if maxVal and price<=maxVal then _abTryBuy(owner,uuid,listing) end
            end
        end
    end

